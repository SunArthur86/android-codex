<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base dark theme — Material3 -->
    <style name="Theme.CodexMobile" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color (Codex blue) -->
        <item name="colorPrimary">@color/codex_primary</item>
        <item name="colorPrimaryVariant">@color/codex_primary_dark</item>
        <item name="colorOnPrimary">@color/codex_white</item>

        <!-- Surface / background -->
        <item name="android:windowBackground">@color/codex_bg</item>
        <item name="android:colorBackground">@color/codex_bg</item>
        <item name="colorSurface">@color/codex_surface</item>
        <item name="colorOnSurface">@color/codex_text_primary</item>

        <!-- Fullscreen immersive -->
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/codex_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowTranslucentStatus">false</item>
    </style>

</resources>
