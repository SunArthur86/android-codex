<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_main.xml — Codex Mobile
  FrameLayout containing the full-screen WebView with a splash overlay
  that is visible until the PWA finishes loading.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/codex_bg">

    <!-- ── Primary WebView (PWA host) ── -->
    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── Splash overlay (shown on launch, hidden after page load) ── -->
    <LinearLayout
        android:id="@+id/splash_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/codex_bg"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/codex_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <ProgressBar
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="24dp"
            android:indeterminateTint="@color/codex_primary" />

    </LinearLayout>

</FrameLayout>
