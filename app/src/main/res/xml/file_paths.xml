<?xml version="1.0" encoding="utf-8"?>
<!--
    Codex Mobile — FileProvider Paths

    Required by the Web Share API bridge: when the PWA calls
    navigator.share({ files: [...] }) or navigator.shareFile(),
    the native Android shell creates a content:// URI via FileProvider.

    Exposed directories:
      • files-path     — app-internal files (downloaded/exported blobs)
      • cache-path     — temporary shared files (cleaned automatically)
      • external-files — shared media on external storage
      • external-cache — temporary files on external storage

    The authority must match AndroidManifest:
        android:authorities="${applicationId}.fileprovider"
-->
<paths xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- App-internal files directory -->
    <files-path
        name="files"
        path="." />

    <!-- App-internal cache (temp share targets) -->
    <cache-path
        name="cache"
        path="." />

    <!-- External files dir (e.g. Downloads) -->
    <external-files-path
        name="external_files"
        path="." />

    <!-- External cache for large temporary blobs -->
    <external-cache-path
        name="external_cache"
        path="." />

    <!-- Root external storage (Android 10+ scoped) -->
    <external-path
        name="external"
        path="." />

</paths>
