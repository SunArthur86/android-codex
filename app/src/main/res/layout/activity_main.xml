<?xml version="1.0" encoding="utf-8"?>
<!--
    Codex Mobile — MainActivity Layout

    Structure:
      ┌─────────────────────────────────┐
      │  Top progress bar (hidden)       │  ← shows during page load
      ├─────────────────────────────────┤
      │                                  │
      │      WebView (full-screen)       │  ← loads index.html PWA
      │                                  │
      ├─────────────────────────────────┤
      │  Error / offline overlay         │  ← shown when WebView fails
      └─────────────────────────────────┘

    The WebView fills the entire screen so the PWA's own app-bar and
    bottom navigation provide the visual chrome.  The overlay sits
    on top and is toggled from Kotlin/Java when connectivity fails.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true">

    <!-- ═══ WebView ═══ -->
    <android.webkit.WebView
        android:id="@+id/webview"
        style="@style/CodexWebView" />

    <!-- ═══ Top loading progress bar ═══ -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress_bar"
        style="@style/LoadingProgressBar"
        android:layout_gravity="top" />

    <!-- ═══ Splash / loading container ═══ -->
    <!-- Shown while WebView initialises, then animated away -->
    <LinearLayout
        android:id="@+id/splash_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/splash_bg"
        android:visibility="visible"
        tools:visibility="gone">

        <!-- Codex hexagon logo placeholder -->
        <TextView
            android:id="@+id/splash_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⬢"
            android:textSize="72sp"
            android:textColor="@color/accent"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Codex Mobile"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Coding Agent"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />

        <ProgressBar
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginTop="32dp"
            android:indeterminateTint="@color/accent" />
    </LinearLayout>

    <!-- ═══ Error / Offline overlay ═══ -->
    <!-- Toggled via View.GONE when WebView successfully loads -->
    <LinearLayout
        android:id="@+id/error_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="@color/bg_primary"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📴"
            android:textSize="56sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="无法加载"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/error_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="请检查网络连接后重试"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="重试"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/accent"
            app:cornerRadius="24dp"
            android:paddingHorizontal="32dp" />

    </LinearLayout>

</FrameLayout>
